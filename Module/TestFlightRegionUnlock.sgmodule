#!name=TestFlight地区解锁
#!desc=解除TestFlight的区域限制，支持tvOS。
#!category=功能增强
#!requirement=CORE_VERSION>=20
# Converted sources: TestFlight地区解锁
# Generated by scripts/loon2surge.py

[Rule]
DOMAIN,testflight.apple.com,DIRECT

[Body Rewrite]
http-request ^https?:\/\/testflight\.apple\.com\/v\d\/accounts\/.+?\/install$ "storefrontId"\x20:\x20"\d{6}-\d{2},\d{2}", "storefrontId":"143441-19,29",

[MITM]
hostname = %APPEND% testflight.apple.com
