#!name=360摄像机去广告
#!desc=Converted from https://kelee.one/Tool/Loon/Lpx/360SmartCamera_remove_ads.lpx
#!requirement=CORE_VERSION>=20
# Converted sources: 360摄像机去广告
# Generated by scripts/loon2surge.py

[Rule]
DOMAIN,ad.jia.360.cn,REJECT
DOMAIN,ad.iot.360.cn,REJECT

[Body Rewrite]
http-response-jq ^https:\/\/jia\.360\.cn\/conf\/v1\.json 'delpaths([["tab_conf"],["ad_conf"],["activity"]])'

[MITM]
hostname = %APPEND% jia.360.cn
